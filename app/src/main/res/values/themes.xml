<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Base.Theme.Instagram_clone" parent="Theme.MaterialComponents.NoActionBar">
        <!-- Primary Brand Color -->
        <item name="colorPrimary">@color/instagram_blue</item>
        <item name="colorPrimaryDark">@color/instagram_blue_dark</item>
        <item name="colorAccent">@color/instagram_blue</item>
        <item name="colorOnPrimary">@color/white</item>

        <!-- Background -->
        <item name="android:colorBackground">@color/background_primary</item>
        <item name="android:windowBackground">@color/background_primary</item>

        <!-- Status Bar — Dark -->
        <item name="android:statusBarColor">@color/status_bar_color</item>
        <item name="android:windowLightStatusBar">false</item>
        
        <!-- Fix Edge To Edge overlapping on API 35+ -->
        <item name="android:fitsSystemWindows">true</item>

        <!-- Navigation Bar -->
        <item name="android:navigationBarColor">@color/nav_bar_color</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="o_mr1">false</item>

        <!-- Text Colors -->
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:textColorHint">@color/text_tertiary</item>

        <!-- EditText cursor -->
        <item name="colorControlActivated">@color/instagram_blue</item>
    </style>

    <style name="Theme.Instagram_clone" parent="Base.Theme.Instagram_clone" />

    <!-- Instagram Blue Button Style -->
    <style name="InstagramButton" parent="Widget.MaterialComponents.Button">
        <item name="android:backgroundTint">@color/instagram_blue</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="cornerRadius">10dp</item>
        <item name="android:letterSpacing">0.01</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="elevation">0dp</item>
    </style>

    <!-- Outlined Button Style -->
    <style name="InstagramButtonOutlined" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:textColor">@color/instagram_blue</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="cornerRadius">10dp</item>
        <item name="strokeColor">@color/divider_color</item>
        <item name="strokeWidth">1dp</item>
        <item name="rippleColor">@color/ripple_dark</item>
    </style>

    <!-- Secondary Button (Edit Profile, Following) -->
    <style name="InstagramButtonSecondary" parent="Widget.MaterialComponents.Button">
        <item name="android:backgroundTint">@color/surface_elevated</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="cornerRadius">8dp</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="elevation">0dp</item>
    </style>

    <!-- Text Input Style -->
    <style name="InstagramTextInput" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">@color/input_background</item>
        <item name="boxStrokeColor">@color/divider_color</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
        <item name="hintTextColor">@color/text_secondary</item>
        <item name="android:textColorHint">@color/text_tertiary</item>
        <item name="boxStrokeWidth">0.5dp</item>
        <item name="boxStrokeWidthFocused">1dp</item>
    </style>

    <!-- Toolbar Style -->
    <style name="InstagramToolbar" parent="Widget.MaterialComponents.Toolbar">
        <item name="android:background">@color/toolbar_background</item>
        <item name="titleTextColor">@color/text_primary</item>
    </style>

    <style name="ShapeAppearanceOverlay.App.CornerSize10Percent" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">10%</item>
    </style>

</resources>