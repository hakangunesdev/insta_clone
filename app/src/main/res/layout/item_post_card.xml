<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardBackgroundColor="@color/surface_card"
    app:cardElevation="0dp"
    app:strokeWidth="0dp"
    app:cardCornerRadius="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Post Header: Avatar + Username + Time -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="14dp">

            <FrameLayout
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:layout_marginEnd="10dp">
                <View android:layout_width="34dp" android:layout_height="34dp"
                    android:background="@drawable/avatar_gradient_ring" />
                <FrameLayout
                    android:layout_width="30dp" android:layout_height="30dp"
                    android:layout_gravity="center"
                    android:background="@drawable/circle_avatar_bg">
                    <TextView android:id="@+id/postUserInitial"
                        android:layout_width="match_parent" android:layout_height="match_parent"
                        android:gravity="center" android:textColor="@color/white"
                        android:textSize="13sp" android:fontFamily="sans-serif-medium"
                        tools:text="G" />
                    <de.hdodenhof.circleimageview.CircleImageView
                        android:id="@+id/postProfileImage"
                        android:layout_width="match_parent" android:layout_height="match_parent"
                        android:visibility="gone"
                        android:contentDescription="Profil" />
                </FrameLayout>
            </FrameLayout>

            <TextView android:id="@+id/postUserEmail"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:textSize="13sp"
                android:textColor="@color/text_primary" android:fontFamily="sans-serif-medium"
                android:singleLine="true" android:ellipsize="end"
                android:clickable="true" android:focusable="true"
                tools:text="kullanici" />

            <TextView android:id="@+id/postTimeAgo"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textSize="12sp" android:textColor="@color/text_secondary"
                tools:text="2sa nce" />
        </LinearLayout>

        <!-- Post Image -->
        <ImageView android:id="@+id/postImage"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:adjustViewBounds="true" android:minHeight="200dp" android:maxHeight="500dp"
            android:scaleType="centerCrop" android:background="@color/input_background"
            android:contentDescription="Post image"
            tools:srcCompat="@tools:sample/backgrounds/scenic" />

        <!-- Action Buttons Row -->
        <LinearLayout
            android:layout_width="match_parent" android:layout_height="44dp"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:paddingHorizontal="8dp">
            <ImageButton android:id="@+id/likeButton"
                android:layout_width="40dp" android:layout_height="40dp"
                android:background="@drawable/ripple_circle" android:src="@drawable/ic_like"
                android:contentDescription="@string/like" android:scaleType="center" />
            <ImageButton android:id="@+id/commentButton"
                android:layout_width="40dp" android:layout_height="40dp"
                android:background="@drawable/ripple_circle" android:src="@drawable/ic_comment"
                android:contentDescription="@string/comment_label" android:scaleType="center" />
            <ImageButton android:id="@+id/shareButton"
                android:layout_width="40dp" android:layout_height="40dp"
                android:background="@drawable/ripple_circle" android:src="@drawable/ic_share"
                android:contentDescription="@string/share_post" android:scaleType="center" />
        </LinearLayout>

        <!-- Like Count -->
        <TextView android:id="@+id/likeCountText"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:paddingHorizontal="14dp" android:textSize="13sp"
            android:textColor="@color/text_primary" android:fontFamily="sans-serif-medium"
            android:visibility="gone" tools:text="24 beğenme" />

        <!-- Comment Section: Username + Caption -->
        <LinearLayout
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:paddingHorizontal="14dp"
            android:paddingTop="4dp">
            <TextView android:id="@+id/postCommentUser"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textSize="13sp" android:textColor="@color/text_primary"
                android:fontFamily="sans-serif-medium" android:layout_marginEnd="6dp"
                tools:text="kullanici" />
            <TextView android:id="@+id/postComment"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:textSize="13sp"
                android:textColor="@color/text_primary" android:lineSpacingExtra="2dp"
                tools:text="Bu harika bir fotoğraf!" />
        </LinearLayout>

        <!-- Comment Count (View All) -->
        <TextView android:id="@+id/commentCountText"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:paddingHorizontal="14dp" android:paddingTop="4dp" android:paddingBottom="12dp"
            android:textSize="13sp" android:textColor="@color/text_secondary"
            android:visibility="gone" android:clickable="true" android:focusable="true"
            tools:text="8 yorumun tümünü gr" />

        <View android:layout_width="match_parent" android:layout_height="0.5dp"
            android:background="@color/divider_color" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
