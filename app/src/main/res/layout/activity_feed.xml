<?xml version="1.0" encoding="utf-8"?>
<LinearLayout android:fitsSystemWindows="true" xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_primary"
    tools:context=".presentation.feed.FeedActivity">

    <!-- Custom Instagram Toolbar -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/toolbar_background"
        android:elevation="1dp"
        android:paddingHorizontal="16dp">
<LinearLayout
            android:layout_width="match_parent" android:layout_height="match_parent"
            android:orientation="horizontal" android:gravity="center_vertical">
            <TextView android:id="@+id/toolbarTitle"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="Instagram"
                android:textSize="26sp" android:textColor="@color/text_primary"
                android:fontFamily="cursive" android:letterSpacing="0.01" />
            <ImageButton android:id="@+id/addPostButton"
                android:layout_width="40dp" android:layout_height="40dp"
                android:background="@drawable/ripple_circle" android:src="@drawable/ic_add"
                android:contentDescription="@string/add_post" android:scaleType="center"
                android:layout_marginEnd="4dp" />
            <ImageButton android:id="@+id/dmButton"
                android:layout_width="40dp" android:layout_height="40dp"
                android:background="@drawable/ripple_circle" android:src="@drawable/ic_send"
                android:contentDescription="Mesajlar" android:scaleType="center"
                android:layout_marginEnd="4dp" />
            <ImageButton android:id="@+id/searchButton"
                android:layout_width="40dp" android:layout_height="40dp"
                android:background="@drawable/ripple_circle" android:src="@drawable/ic_search"
                android:contentDescription="Ara" android:scaleType="center"
                android:layout_marginEnd="4dp" />
            <ImageButton android:id="@+id/profileButton"
                android:layout_width="40dp" android:layout_height="40dp"
                android:background="@drawable/ripple_circle" android:src="@drawable/ic_person"
                android:contentDescription="Profil" android:scaleType="center"
                android:layout_marginEnd="4dp" />
            <ImageButton android:id="@+id/logoutButton"
                android:layout_width="40dp" android:layout_height="40dp"
                android:background="@drawable/ripple_circle" android:src="@drawable/ic_logout"
                android:contentDescription="@string/logout" android:scaleType="center" />
        </LinearLayout>
    </com.google.android.material.appbar.MaterialToolbar>

    <View android:layout_width="match_parent" android:layout_height="0.5dp"
        android:background="@color/divider_color" />

    <!-- SwipeRefreshLayout wrapping RecyclerView -->
    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipeRefresh"
        android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1">
        <FrameLayout
            android:layout_width="match_parent" android:layout_height="match_parent">
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerView"
                android:layout_width="match_parent" android:layout_height="match_parent"
                android:clipToPadding="false" android:paddingTop="4dp"
                android:paddingBottom="16dp" android:scrollbars="vertical" />
<LinearLayout android:id="@+id/emptyState"
                android:layout_width="match_parent" android:layout_height="match_parent"
                android:orientation="vertical" android:gravity="center"
                android:visibility="gone" android:padding="48dp">
                <ImageView android:layout_width="80dp" android:layout_height="80dp"
                    android:src="@drawable/ic_image_placeholder" android:alpha="0.4"
                    android:layout_marginBottom="16dp" android:contentDescription="@null" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/no_posts" android:textSize="18sp"
                    android:textColor="@color/text_primary" android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="8dp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/no_posts_desc" android:textSize="14sp"
                    android:textColor="@color/text_secondary" />
            </LinearLayout>
            <com.google.android.material.progressindicator.CircularProgressIndicator
                android:id="@+id/progressBar"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_gravity="center" android:visibility="gone"
                app:indicatorColor="@color/instagram_blue" app:trackColor="@color/divider_color"
                app:indicatorSize="48dp" android:indeterminate="true" />
        </FrameLayout>
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
</LinearLayout>



