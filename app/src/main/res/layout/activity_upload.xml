<?xml version="1.0" encoding="utf-8"?>
<LinearLayout android:fitsSystemWindows="true" xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_primary"
    tools:context=".presentation.upload.UploadActivity">

    <!-- Toolbar -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/toolbar_background"
        android:elevation="1dp"
        android:paddingHorizontal="4dp">
<LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Back Button -->
            <ImageButton
                android:id="@+id/backButton"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/ripple_circle"
                android:src="@drawable/ic_back"
                android:contentDescription="Geri"
                android:scaleType="center" />

            <!-- Title -->
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/new_post"
                android:textSize="18sp"
                android:textColor="@color/text_primary"
                android:fontFamily="sans-serif-medium"
                android:layout_marginStart="12dp" />

            <!-- Share Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/shareButton"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="@string/share"
                android:textSize="14sp"
                android:textAllCaps="false"
                app:backgroundTint="@color/instagram_blue"
                app:cornerRadius="8dp"
                android:paddingHorizontal="20dp"
                android:layout_marginEnd="8dp" />

        </LinearLayout>

    </com.google.android.material.appbar.MaterialToolbar>

    <!-- Toolbar divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="@color/divider_color" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">
<LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Image Selection Area -->
            <FrameLayout
                android:id="@+id/imageContainer"
                android:layout_width="match_parent"
                android:layout_height="320dp"
                android:layout_marginBottom="20dp"
                android:background="@drawable/dashed_border"
                android:clickable="true"
                android:focusable="true">

                <!-- Placeholder State -->
<LinearLayout
                    android:id="@+id/placeholderContainer"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center">

                    <ImageView
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:src="@drawable/ic_image_placeholder"
                        android:layout_marginBottom="12dp"
                        android:contentDescription="@null" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/tap_to_select"
                        android:textSize="15sp"
                        android:textColor="@color/text_secondary"
                        android:fontFamily="sans-serif" />

                </LinearLayout>

                <!-- Selected Image -->
                <ImageView
                    android:id="@+id/uploadImageView"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:visibility="gone"
                    android:contentDescription="@string/select_photo" />

            </FrameLayout>

            <!-- Comment Input -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/commentInputLayout"
                style="@style/InstagramTextInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:hintEnabled="true"
                android:hint="@string/hint_comment"
                app:counterEnabled="true"
                app:counterMaxLength="300">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/uploadCommentText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textMultiLine"
                    android:minLines="3"
                    android:maxLines="6"
                    android:textSize="14sp"
                    android:textColor="@color/text_primary"
                    android:gravity="top" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Upload Progress -->
            <com.google.android.material.progressindicator.LinearProgressIndicator
                android:id="@+id/uploadProgress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone"
                app:indicatorColor="@color/instagram_blue"
                app:trackColor="@color/divider_color"
                android:indeterminate="true"
                app:trackCornerRadius="4dp" />

        </LinearLayout>

    </ScrollView>

</LinearLayout>



